// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Webhook {
  id        String   @id @default(uuid())
  userId    String   
  method    String   
  path      String   
  headers   String   
  query     String  
  body      String   
  createdAt DateTime @default(now()) 
}
